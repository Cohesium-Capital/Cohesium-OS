# LLM brain
# Sonnet is the recommended starting point: better nuance than Haiku on
# sentiment / switching-intent calls, ~5x cheaper than Opus. Demote to
# claude-haiku-4-5 once you've measured quality on a labeled set.
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
